# Yellowstone gRPC endpoint (include scheme and port)
YELLOWSTONE_ENDPOINT=
YELLOWSTONE_TOKEN=

# Solana RPC
RPC_URL=

# Signing wallet — base64-encoded keypair JSON
KEYPAIR_JSON=

# LLM tip optimizer (any OpenAI-compatible provider)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Hard cap on tip per bundle (lamports). Default: 500000
# TIP_CEILING_LAMPORTS=500000

# Jito block engine regions — leave unset to use all five mainnet regions
# JITO_BLOCK_ENGINE_URLS=https://amsterdam.mainnet.block-engine.jito.wtf/api/v1,...
