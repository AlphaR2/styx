
# Yellowstone gRPC (slot + transaction stream). Endpoint must include the scheme + port.
YELLOWSTONE_ENDPOINT=https://your-region.grpc.example.dev:443
YELLOWSTONE_TOKEN=your_yellowstone_token
RPC_URL=https://your-rpc.example.dev/?api_key=your_rpc_key

# Wallet that signs + pays for every bundle.
# Base64-encode your Solana keypair and paste it here (no filesystem needed — safe for teams).
# Generate with:  base64 -w 0 < your-keypair.json
KEYPAIR_JSON=your_base64_keypair_here

# ── AI tip optimizer — bring your own LLM 
# Set these three vars to enable the AI regime classifier. Any LLM works. Just plug in
# whatever you have. Without them Styx still runs, falling back to the p95 baseline.
#
# LLM_BASE_URL  full endpoint URL for the /chat/completions (or equivalent) call
# LLM_API_KEY   your API key for that provider
# LLM_MODEL     model name as the provider expects it
# LLM_KIND      wire protocol: "openai-compatible" (default) or "anthropic"
#
# Examples:
#   Together AI:  LLM_BASE_URL=https://api.together.xyz/v1/chat/completions
#                 LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#   OpenAI:       LLM_BASE_URL=https://api.openai.com/v1/chat/completions
#                 LLM_MODEL=gpt-4o-mini
#   Groq:         LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
#                 LLM_MODEL=llama-3.3-70b-versatile
#   Anthropic:    LLM_BASE_URL=https://api.anthropic.com/v1/messages
#                 LLM_MODEL=claude-haiku-4-5-20251001
#                 LLM_KIND=anthropic
#   Local Ollama: LLM_BASE_URL=http://localhost:11434/v1/chat/completions
#                 LLM_MODEL=llama3
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
#LLM_KIND=openai-compatible

# Jito block engines. Bundles are fanned out to EVERY listed region concurrently —
# a bundle only lands if it reaches the engine feeding the current Jito leader, so
# submitting to all regions dramatically improves landing rate. Leave both unset to
# use all known mainnet regions (recommended).
#   JITO_BLOCK_ENGINE_URLS  comma-separated list (fanned out to all)
#   JITO_BLOCK_ENGINE_URL   single region (back-compat override; ignored if _URLS set)
# Regions: amsterdam | frankfurt | ny | tokyo | slc (.mainnet.block-engine.jito.wtf/api/v1)
#JITO_BLOCK_ENGINE_URLS=https://amsterdam.mainnet.block-engine.jito.wtf/api/v1,https://frankfurt.mainnet.block-engine.jito.wtf/api/v1,https://ny.mainnet.block-engine.jito.wtf/api/v1,https://tokyo.mainnet.block-engine.jito.wtf/api/v1,https://slc.mainnet.block-engine.jito.wtf/api/v1
#JITO_BLOCK_ENGINE_URL=https://frankfurt.mainnet.block-engine.jito.wtf/api/v1
TIP_CEILING_LAMPORTS=500000
SNIPE_TIP_CEILING_LAMPORTS=5000000

# ── Testing / calibration ──────────────────────────────────────────────────
# Force every bundle to use this exact tip (lamports), bypassing the AI formula.
# Use this to confirm high tips land before tuning compute_tip() floors.
# Remove or comment out to re-enable the AI optimizer.
#TEST_TIP_LAMPORTS=500000

